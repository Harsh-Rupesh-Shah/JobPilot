# Database
MONGODB_URI=mongodb+srv://...

# Security (You can generate random strings for these)
SECRET_KEY=your_random_string_here
JWT_SECRET_KEY=your_random_string_here_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI & Tools (Required later for the Agents phase)
OPENROUTER_API_KEY=sk-or-...
TAVILY_API_KEY=tvly-...

# Observability (Optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-job-copilot
LANGCHAIN_API_KEY=ls__...

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
